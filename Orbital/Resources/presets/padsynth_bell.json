{
  "name": "PADsynth Bell",
  "rose": {
    "freq": 0.2,
    "leafFactor": 3,
    "phase": 0,
    "amp": 4
  },
  "effects": {
    "reverbPreset": 4,
    "reverbWetDryMix": 50,
    "delayTime": 0.3,
    "delayFeedback": 15,
    "delayLowPassCutoff": 5000,
    "delayWetDryMix": 20
  },
  "arrow": {
    "compose": [
      { "prod": [
        { "const": { "name": "overallAmp", "val": 1.0 } },
        { "compose": [
          { "prod": [
            { "const": { "name": "freq", "val": 300 } },
            { "constOctave": { "name": "osc1Octave", "val": 0 } },
            { "constCent": { "name": "osc1CentDetune", "val": 0 } },
            { "identity": {} }
          ]},
          { "padSynthWavetable": {
            "name": "osc1",
            "params": {
              "baseShape": "1/n\u00b2",
              "tilt": 0.0,
              "bandwidthCents": 50.0,
              "bwScale": 1.0,
              "profileShape": "Gaussian",
              "stretch": 1.15,
              "selectedInstrument": null,
              "envelopeCoefficients": null
            },
            "width": { "const": { "name": "osc1Width", "val": 1 } }
          }}
        ]},
        { "envelope": {
          "name": "ampEnv",
          "attack": 0.1,
          "decay": 1.0,
          "sustain": 1.0,
          "release": 0.1,
          "scale": 1
        }}
      ]},
      { "lowPassFilter": {
        "name": "filter",
        "cutoff": { "sum": [
          { "const": { "name": "cutoffLow", "val": 200 } },
          { "prod": [
            { "const": { "name": "cutoff", "val": 11800 } },
            { "envelope": {
              "name": "filterEnv",
              "attack": 0.1,
              "decay": 0.3,
              "sustain": 1.0,
              "release": 0.1,
              "scale": 1
            }}
          ]}
        ]},
        "resonance": { "const": { "name": "resonance", "val": 1.6 } }
      }}
    ]
  }
}
