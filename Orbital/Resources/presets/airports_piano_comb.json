{
 "name"   : "Airports Piano Comb",
 "rose"   : {"freq": 0.2, "leafFactor": 3, "phase": 1.0, "amp": 3},
 "effects": {"reverbPreset": 8, "delayTime": 0.05, "delayLowPassCutoff": 1500, "delayFeedback": 15, "reverbWetDryMix": 50, "delayWetDryMix": 15},
 "arrow"  : {
  "sum": [
   {
    "compose": [
     {
      "prod": [
        { "const": {"val": 0.5, "name": "overallAmp"}},
        { "const": {"val": 1.0, "name": "overallAmp2"}},
        {
         "sum": [
           {
            "prod": [
              { "const": {"val": 0.8, "name": "osc1Mix"} },
              { "noiseSmoothStep": {"noiseFreq": 3500, "min": -1, "max": 1} }
            ]
           },
           {
            "prod": [
              { "const": {"val": 0.5, "name": "osc2Mix"} },
              { "noiseSmoothStep": {"noiseFreq": 2000, "min": -1, "max": 1} }
            ]
           }
         ]
        },
        { "envelope": { "decay": 0.15, "sustain": 0, "attack": 0.005, "name": "ampEnv", "release": 2.0, "scale": 1 } }
       ]
     },
     {
      "lowPassFilter": {
        "cutoff": { "prod": [
          { "const": {"name": "freq", "val": 300} },
          { "const": {"name": "exLPFMultiplier", "val": 2} }
        ]},
        "resonance": { "const": {"name": "exLPFResonance", "val": 0.5} },
        "name": "exLPF1"
      }
     },
     {
      "combFilter": {
        "frequency":
         { "prod": [
           { "const": {"name": "freq", "val": 300} },
           { "constOctave": {"name": "combOctave", "val": 0} },
           { "constCent": {"name": "combCentDetune1", "val": -4} }
         ]},
        "feedback": { "const": {"name": "combFeedback", "val": 0.98} },
        "name"    : "comb1a"
      }
     },
     {
      "lowPassFilter": {
        "cutoff": { "const": {"name": "interLPFCutoff", "val": 3000} },
        "resonance": { "const": {"name": "interLPFResonance", "val": 0.5} },
        "name": "interLPF1"
      }
     },
     {
      "combFilter": {
        "frequency":
         { "prod": [
           { "const": {"name": "freq", "val": 300} },
           { "constOctave": {"name": "combOctave", "val": 0} },
           { "constCent": {"name": "combCentDetune1", "val": -4} }
         ]},
        "feedback": { "const": {"name": "combFeedback2", "val": 0.7} },
        "name"    : "comb1b"
      }
     },
     {
      "lowPassFilter": {
        "cutoff":
         { "prod": [
           { "const": {"name": "freq", "val": 300} },
           { "const": {"name": "combLPFMultiplier", "val": 8} }
         ]},
        "resonance": { "const": {"name": "combLPFResonance", "val": 0.7} },
        "name": "combLPF1"
      }
     }
    ]
   },
   {
    "compose": [
     {
      "prod": [
        { "const": {"val": 0.5, "name": "overallAmp"}},
        { "const": {"val": 1.0, "name": "overallAmp2"}},
        {
         "sum": [
           {
            "prod": [
              { "const": {"val": 0.8, "name": "osc1Mix"} },
              { "noiseSmoothStep": {"noiseFreq": 3500, "min": -1, "max": 1} }
            ]
           },
           {
            "prod": [
              { "const": {"val": 0.5, "name": "osc2Mix"} },
              { "noiseSmoothStep": {"noiseFreq": 2000, "min": -1, "max": 1} }
            ]
           }
         ]
        },
        { "envelope": { "decay": 0.15, "sustain": 0, "attack": 0.005, "name": "ampEnv", "release": 2.0, "scale": 1 } }
       ]
     },
     {
      "lowPassFilter": {
        "cutoff": { "prod": [
          { "const": {"name": "freq", "val": 300} },
          { "const": {"name": "exLPFMultiplier", "val": 2} }
        ]},
        "resonance": { "const": {"name": "exLPFResonance", "val": 0.5} },
        "name": "exLPF2"
      }
     },
     {
      "combFilter": {
        "frequency":
         { "prod": [
           { "const": {"name": "freq", "val": 300} },
           { "constOctave": {"name": "combOctave", "val": 0} },
           { "constCent": {"name": "combCentDetune2", "val": 4} }
         ]},
        "feedback": { "const": {"name": "combFeedback", "val": 0.98} },
        "name"    : "comb2a"
      }
     },
     {
      "lowPassFilter": {
        "cutoff": { "const": {"name": "interLPFCutoff", "val": 3000} },
        "resonance": { "const": {"name": "interLPFResonance", "val": 0.5} },
        "name": "interLPF2"
      }
     },
     {
      "combFilter": {
        "frequency":
         { "prod": [
           { "const": {"name": "freq", "val": 300} },
           { "constOctave": {"name": "combOctave", "val": 0} },
           { "constCent": {"name": "combCentDetune2", "val": 4} }
         ]},
        "feedback": { "const": {"name": "combFeedback2", "val": 0.7} },
        "name"    : "comb2b"
      }
     },
     {
      "lowPassFilter": {
        "cutoff":
         { "prod": [
           { "const": {"name": "freq", "val": 300} },
           { "const": {"name": "combLPFMultiplier", "val": 8} }
         ]},
        "resonance": { "const": {"name": "combLPFResonance", "val": 0.7} },
        "name": "combLPF2"
      }
     }
    ]
   }
  ]
 }
}
